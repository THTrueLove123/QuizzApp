<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="414.0" prefWidth="345.0" spacing="20.0" styleClass="Container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nguyentanhuy.quizzapp.PrimaryController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="Subject" text="English App" />
      <Button mnemonicParsing="false" onAction="#manageQuestion" styleClass="Button" text="Quản Lý Câu Hỏi" />
      <Button layoutX="130.0" layoutY="223.0" mnemonicParsing="false" onAction="#practiceQuestion" styleClass="Button" text="Luyện Tập" />
      <Button layoutX="130.0" layoutY="201.0" mnemonicParsing="false" onAction="#examQuestion" styleClass="Button" text="Luyện Thi" />
      <ComboBox fx:id="cbo" onAction="#changeCBO" prefWidth="150.0" styleClass="Button" />
   </children>
</VBox>
